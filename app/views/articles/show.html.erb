<% content_for :title, "#{@article.title} — Ruby Blog" %>

<p><%= link_to "Back to articles", articles_path %></p>

<h1><%= @article.title %></h1>

<p><%= simple_format(@article.body) %></p>

<h2>Comments</h2>

<% @comments.each do |comment| %>
  <div>
    <p><%= simple_format(comment.body) %></p>
    <p><small><%= comment.user.email %> · <%= l(comment.created_at, format: :short) %></small></p>
    <% if user_signed_in? && (comment.user_id == current_user.id || @article.user_id == current_user.id) %>
      <%= button_to "Delete comment", article_comment_path(@article, comment), method: :delete, form: { data: { turbo_confirm: "Delete this comment?" } } %>
    <% end %>
  </div>
<% end %>

<% if user_signed_in? %>
  <h3>Add a comment</h3>
  <%= form_with model: [@article, Comment.new], local: true do |form| %>
    <div>
      <%= form.label :body, "Comment" %>
      <%= form.text_area :body, rows: 5 %>
    </div>
    <div>
      <%= form.submit "Post comment" %>
    </div>
  <% end %>
<% else %>
  <p><%= link_to "Sign in", new_user_session_path %> to comment.</p>
<% end %>

<% if user_signed_in? && @article.user_id == current_user.id %>
  <p>
    <%= link_to "Edit", edit_article_path(@article) %>
    <%= button_to "Destroy", article_path(@article), method: :delete, form: { data: { turbo_confirm: "Are you sure?" } } %>
  </p>
<% end %>
