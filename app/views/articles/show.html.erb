<% content_for :title, "#{@article.title} — Ruby Blog" %>

<p><%= link_to "Back to articles", articles_path %></p>

<h1><%= @article.title %></h1>

<p><%= simple_format(@article.body) %></p>

<% if user_signed_in? && @article.user_id == current_user.id %>
  <p>
    <%= link_to "Edit", edit_article_path(@article) %>
    <%= button_to "Destroy", article_path(@article), method: :delete, form: { data: { turbo_confirm: "Are you sure?" } } %>
  </p>
<% end %>
